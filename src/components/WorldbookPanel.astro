---
---
<div class="panel area-worldbook">
  <h2>📖 世界书条目</h2>

  <!-- AI 单条生成 -->
  <div class="wb-ai-single-card">
    <h4 class="wb-ai-single-title">🤖 AI 单条生成（自动叠加）</h4>
    <p class="wb-ai-single-copy">AI 会自动读取已有词条，确保世界观连贯且不重复。</p>
    <div class="wb-ai-single-actions">
      <input type="text" id="wbSinglePrompt" placeholder="定向要求(可选)，如：写一把专属武器..." style="flex: 1;" />
      <button id="btnAiSingleWb" class="btn wb-ai-single-btn">🎲 生成 1 条</button>
    </div>
    <div class="wb-ai-single-toggles">
      <div class="wb-ai-single-toggle">
        <input type="checkbox" id="wbIncludeCharData" checked />
        <label for="wbIncludeCharData">融合【角色名与描述】</label>
      </div>
      <div class="wb-ai-single-toggle">
        <input type="checkbox" id="wbIncludeOtherEntries" checked />
        <label for="wbIncludeOtherEntries">融合【已有世界书条目】</label>
      </div>
    </div>
  </div>

  <!-- ★ AI 智能整理（美化版） -->
  <div class="wb-organize-wrap">
    <div class="organize-header-row">
      <div class="organize-icon-wrap">
        <span class="organize-icon">🧹</span>
      </div>
      <div class="organize-title-wrap">
        <span class="organize-title">AI 智能整理</span>
        <span class="organize-subtitle">自动优化插入位置 · 深度 · 顺序 · 概率</span>
      </div>
      <button id="btnAiOrganize" class="btn-organize-magic">
        <span class="btn-magic-icon">⚡</span>
        <span class="btn-magic-text">一键整理</span>
      </button>
    </div>
    <div id="organizeStatus" class="organize-status-bar"></div>
  </div>
  <div id="organizePreview" class="organize-preview-container" style="display: none;"></div>

  <!-- ★ AI 触发词生成 -->
  <div class="wb-keygen-wrap">
    <div class="organize-header-row">
      <div class="organize-icon-wrap wb-keygen-icon-wrap">
        <span class="organize-icon">🗝️</span>
      </div>
      <div class="organize-title-wrap">
        <span class="organize-title wb-keygen-title">AI 触发词生成</span>
        <span class="organize-subtitle">为当前世界书条目批量补全更自然的触发词</span>
      </div>
      <button id="btnAiGenerateKeys" class="btn-organize-magic wb-keygen-btn">
        <span class="btn-magic-icon">✨</span>
        <span class="btn-magic-text">一键补触发词</span>
      </button>
    </div>
    <div id="keygenStatus" class="organize-status-bar"></div>
  </div>

  <div class="wb-entry-toolbar">
    <button id="btnCreateEntry" class="btn btn-add wb-entry-create-btn">新建条目</button>
  </div>

  <!-- 条目列表 -->
  <div id="entriesList"></div>
</div>

<style>
  /* ===== AI 智能整理美化版 ===== */
  .wb-ai-single-card {
    margin-bottom: 20px;
    padding: 16px;
    border-radius: 10px;
    background: color-mix(in srgb, var(--accent-2) 8%, var(--surface-overlay-strong));
    border: 1px dashed color-mix(in srgb, var(--accent-2) 28%, var(--field-border));
    box-shadow: 0 12px 28px color-mix(in srgb, var(--accent-2) 10%, transparent);
  }

  .wb-ai-single-title {
    margin: 0 0 8px 0;
    color: color-mix(in srgb, var(--accent-2) 68%, var(--text-main));
    font-size: 0.9rem;
  }

  .wb-ai-single-copy {
    margin: 0 0 12px 0;
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .wb-ai-single-actions {
    display: flex;
    gap: 10px;
  }

  .wb-ai-single-btn {
    width: auto;
    margin: 0;
    white-space: nowrap;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--accent-2) 92%, white),
      color-mix(in srgb, var(--accent-2) 76%, black)
    );
    border-color: color-mix(in srgb, var(--accent-2) 55%, transparent);
  }

  .wb-ai-single-toggles {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .wb-ai-single-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .wb-ai-single-toggle label {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.78rem;
    cursor: pointer;
    font-weight: normal;
  }


@keyframes organize-shine {
  0%   { background-position: 200% center; }
  50%  { background-position: -200% center; }
  100% { background-position: 200% center; }
}


  .organize-header-row {
    display: flex;
    align-items: center;
    gap: 12px;
    position: relative;
    z-index: 1;
  }

  .organize-icon-wrap {
    width: 40px;
    height: 40px;
    background: linear-gradient(145deg, #fbbf24, #f59e0b);
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 3px 10px rgba(251, 191, 36, 0.35), inset 0 1px 0 rgba(255,255,255,0.25);
    flex-shrink: 0;
  }
  .organize-icon {
    font-size: 1.2rem;
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.25));
  }

  .organize-title-wrap {
    flex: 1;
    min-width: 0;
  }
  .organize-title {
    display: block;
    font-size: 0.88rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--accent-amber) 74%, var(--text-main));
    letter-spacing: 0.03em;
    text-shadow: 0 0 20px color-mix(in srgb, var(--accent-amber) 22%, transparent);
  }
  .organize-subtitle {
    display: block;
    font-size: 0.68rem;
    color: var(--text-muted);
    margin-top: 2px;
  }

  .btn-organize-magic {
    display: flex;
    align-items: center;
    gap: 6px;
    background: linear-gradient(145deg, #f59e0b 0%, #d97706 50%, #b45309 100%);
    color: #fff;
    padding: 10px 18px;
    font-size: 0.8rem;
    font-weight: 700;
    border: none;
    border-radius: 9px;
    cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 3px 12px rgba(245, 158, 11, 0.4), inset 0 1px 0 rgba(255,255,255,0.2);
    flex-shrink: 0;
    font-family: inherit;
    position: relative;
    overflow: hidden;
  }
  .btn-organize-magic::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, rgba(255,255,255,0.15), transparent);
    pointer-events: none;
    border-radius: 9px 9px 0 0;
  }
  .btn-organize-magic:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(245, 158, 11, 0.5), inset 0 1px 0 rgba(255,255,255,0.25);
  }
  .btn-organize-magic:active {
    transform: translateY(0);
  }
  .btn-organize-magic:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
    box-shadow: 0 2px 8px rgba(245, 158, 11, 0.25);
  }
  .btn-magic-icon {
    font-size: 1rem;
    animation: magic-pulse 1.5s infinite;
  }
  @keyframes magic-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(0.95); }
  }
  .btn-magic-text {
    position: relative;
    z-index: 1;
  }

  :root[data-theme="light"] .btn-organize-magic {
    color: #4a2a00;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  :root[data-theme="light"] .wb-keygen-btn {
    color: #082f49;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.16);
  }

  .organize-status-bar {
    font-size: 0.72rem;
    color: var(--text-soft);
    margin-top: 10px;
    padding: 8px 12px;
    background: color-mix(in srgb, var(--surface-overlay) 94%, transparent);
    border-radius: 8px;
    min-height: 28px;
    display: flex;
    align-items: center;
    gap: 6px;
    position: relative;
    z-index: 1;
    border: 1px solid var(--chip-border);
  }

  .organize-status-bar:empty {
    display: none;
  }

  .wb-entry-toolbar {
    display: flex;
    justify-content: stretch;
    margin-bottom: 10px;
  }

  .wb-entry-create-btn {
    width: 100%;
    margin: 0;
    white-space: nowrap;
    padding: 8px 14px;
    font-size: 0.8rem;
    border-radius: 10px;
    box-shadow: 0 6px 18px rgba(16, 185, 129, 0.14);
  }

  @media (max-width: 720px) {
    .wb-entry-create-btn {
      width: 100%;
      min-width: 0;
    }
  }

  .wb-keygen-wrap {
    margin-bottom: 14px;
    padding: 14px 16px;
    border-radius: 12px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(56, 189, 248, 0.09), rgba(14, 165, 233, 0.04));
    border: 1px solid rgba(56, 189, 248, 0.18);
    box-shadow: 0 3px 16px rgba(56, 189, 248, 0.08);
  }

  .wb-keygen-icon-wrap {
    background: linear-gradient(145deg, #38bdf8, #0284c7);
    box-shadow: 0 3px 10px rgba(56, 189, 248, 0.28), inset 0 1px 0 rgba(255,255,255,0.25);
  }

  .wb-keygen-title {
    color: color-mix(in srgb, var(--accent-cyan) 72%, var(--text-main));
    text-shadow: 0 0 18px color-mix(in srgb, var(--accent-cyan) 18%, transparent);
  }

  .wb-keygen-btn {
    background: linear-gradient(145deg, #0ea5e9 0%, #0284c7 52%, #0369a1 100%);
    box-shadow: 0 3px 12px rgba(14, 165, 233, 0.32), inset 0 1px 0 rgba(255,255,255,0.2);
  }

  .wb-keygen-btn:hover {
    box-shadow: 0 6px 20px rgba(14, 165, 233, 0.42), inset 0 1px 0 rgba(255,255,255,0.25);
  }

  /* ===== 预览容器 ===== */
  .organize-preview-container {
    background: linear-gradient(180deg, var(--code-bg), color-mix(in srgb, var(--surface-overlay) 86%, var(--code-bg)));
    border: 1px solid color-mix(in srgb, var(--accent-amber) 28%, var(--code-border));
    border-radius: 12px;
    margin-top: 5px;
    margin-bottom: 14px;
    overflow: hidden;
    box-shadow: 0 6px 24px color-mix(in srgb, var(--text-main) 14%, transparent), inset 0 1px 0 rgba(255,255,255,0.04);
    animation: preview-slide-in 0.35s ease-out;
  }
  @keyframes preview-slide-in {
    from { opacity: 0; transform: translateY(-12px); max-height: 0; }
    to { opacity: 1; transform: translateY(0); max-height: 500px; }
  }

  .organize-preview-header {
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--accent-amber) 15%, transparent),
      color-mix(in srgb, var(--accent-2) 10%, transparent)
    );
    padding: 12px 16px;
    border-bottom: 1px solid color-mix(in srgb, var(--accent-amber) 22%, var(--code-divider));
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .preview-header-title {
    font-size: 0.82rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--accent-amber) 76%, var(--text-main));
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .preview-header-badge {
    font-size: 0.64rem;
    background: var(--surface-soft-success);
    color: color-mix(in srgb, var(--accent-green) 70%, var(--text-main));
    padding: 3px 10px;
    border-radius: 99px;
    font-weight: 600;
    border: 1px solid color-mix(in srgb, var(--accent-green) 24%, var(--chip-border));
  }

  .organize-table-wrap {
    max-height: 260px;
    overflow-y: auto;
  }

  .organize-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.72rem;
  }
  .organize-table th {
    background: color-mix(in srgb, var(--code-header-bg) 92%, transparent);
    color: var(--text-muted);
    padding: 10px 12px;
    text-align: left;
    font-weight: 700;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    position: sticky;
    top: 0;
    z-index: 1;
    border-bottom: 1px solid var(--code-divider);
  }
  .organize-table td {
    padding: 9px 12px;
    border-bottom: 1px solid color-mix(in srgb, var(--code-divider) 84%, transparent);
    color: var(--text-soft);
    transition: background 0.15s ease;
  }
  .organize-table tr:hover td {
    background: color-mix(in srgb, var(--accent-amber) 6%, transparent);
  }
  .organize-table tr:last-child td {
    border-bottom: none;
  }

  .org-name-cell {
    max-width: 110px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 600;
    color: var(--text-main);
  }

  .org-value-cell {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
  }
  .org-changed {
    color: #34d399 !important;
    font-weight: 700;
    background: rgba(16, 185, 129, 0.12);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid rgba(16, 185, 129, 0.2);
  }
  .org-old {
    color: var(--text-muted);
    text-decoration: line-through;
    font-size: 0.62rem;
    margin-right: 5px;
  }

  .org-reason-cell {
    max-width: 150px;
    font-size: 0.64rem;
    color: var(--text-muted);
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .organize-footer {
    padding: 12px 16px;
    background: color-mix(in srgb, var(--surface-overlay) 92%, transparent);
    border-top: 1px solid var(--code-divider);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .organize-stats {
    font-size: 0.7rem;
    color: var(--text-muted);
  }
  .organize-stats strong {
    color: #34d399;
    font-weight: 700;
  }

  .organize-actions {
    display: flex;
    gap: 10px;
  }
  .btn-org-apply {
    background: linear-gradient(145deg, #10b981, #059669) !important;
    color: #fff !important;
    padding: 8px 18px !important;
    font-size: 0.76rem !important;
    font-weight: 700 !important;
    border: none !important;
    border-radius: 7px !important;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
    box-shadow: 0 2px 10px rgba(16, 185, 129, 0.35);
  }
  .btn-org-apply:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(16, 185, 129, 0.45);
  }
  .btn-org-cancel {
    background: var(--field-bg) !important;
    color: var(--text-soft) !important;
    padding: 8px 16px !important;
    font-size: 0.76rem !important;
    font-weight: 600 !important;
    border: 1px solid var(--field-border) !important;
    border-radius: 7px !important;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
  }
  .btn-org-cancel:hover {
    background: var(--field-bg-strong) !important;
    color: var(--text-main) !important;
  }
</style>
