---
---
<footer class="panel workspace-footer-panel">
  <div class="workspace-footer-mark">V4</div>
  <div class="workspace-footer-copy">
    <strong>酒馆卡片构建器</strong>
    <span>作者：wominIII</span>
    <p>用于 SillyTavern 角色卡、世界书、正则与 MVU 工作流。</p>
  </div>
  <div class="workspace-footer-meta">
    <a class="workspace-footer-github" href="https://github.com/wominIII" target="_blank" rel="noopener noreferrer">
      <span>GH</span>
      GitHub 主页
    </a>
    <span>豫ICP备2026000549号</span>
  </div>
</footer>

<style>
  .workspace-footer-panel {
    min-height: 134.5px;
    max-height: none;
    overflow: hidden;
    padding: 12px 14px;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 12px;
    border-color: color-mix(in srgb, var(--accent-cyan) 22%, var(--field-border));
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--surface-elevated) 100%, transparent), color-mix(in srgb, var(--surface-overlay-strong) 92%, transparent)),
      radial-gradient(circle at 90% 0%, color-mix(in srgb, var(--accent-cyan) 12%, transparent), transparent 36%);
  }

  .workspace-footer-mark {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--accent-cyan) 26%, var(--field-border));
    background: color-mix(in srgb, var(--accent-cyan) 10%, var(--chip-bg));
    color: color-mix(in srgb, var(--accent-cyan) 72%, var(--text-main));
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    font-weight: 900;
    box-shadow: inset 0 1px 0 color-mix(in srgb, white 18%, transparent);
  }

  .workspace-footer-copy {
    min-width: 0;
  }

  .workspace-footer-copy strong {
    display: block;
    color: var(--text-main);
    font-size: 0.82rem;
    line-height: 1.2;
  }

  .workspace-footer-copy span {
    display: block;
    margin-top: 2px;
    color: color-mix(in srgb, var(--accent-2) 74%, var(--text-main));
    font-size: 0.66rem;
    font-weight: 800;
  }

  .workspace-footer-copy p {
    margin: 6px 0 0;
    color: var(--text-muted);
    font-size: 0.62rem;
    line-height: 1.45;
  }

  .workspace-footer-meta {
    display: flex;
    flex-direction: column;
    gap: 7px;
    align-items: flex-end;
    justify-content: center;
  }

  .workspace-footer-meta span,
  .workspace-footer-meta a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 24px;
    padding: 3px 9px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent-green) 20%, var(--chip-border));
    background: color-mix(in srgb, var(--accent-green) 10%, var(--chip-bg));
    color: color-mix(in srgb, var(--accent-green) 72%, var(--text-main));
    font-size: 0.54rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    white-space: nowrap;
    text-decoration: none;
  }

  .workspace-footer-github {
    gap: 6px;
    border-color: color-mix(in srgb, var(--accent-cyan) 28%, var(--chip-border)) !important;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent-cyan) 14%, var(--chip-bg)), color-mix(in srgb, var(--accent-2) 10%, var(--surface-overlay))) !important;
    color: color-mix(in srgb, var(--accent-cyan) 74%, var(--text-main)) !important;
    box-shadow: 0 4px 14px color-mix(in srgb, var(--accent-cyan) 12%, transparent);
  }

  .workspace-footer-github span {
    min-height: auto;
    padding: 1px 5px;
    border-radius: 5px;
    border: 1px solid color-mix(in srgb, var(--accent-cyan) 24%, var(--chip-border));
    background: color-mix(in srgb, var(--accent-cyan) 8%, var(--field-bg));
    color: color-mix(in srgb, var(--accent-cyan) 72%, var(--text-main));
    font-size: 0.5rem;
    line-height: 1.2;
  }

  .workspace-footer-meta a:hover {
    border-color: color-mix(in srgb, var(--accent-cyan) 34%, var(--chip-border));
    background: color-mix(in srgb, var(--accent-cyan) 12%, var(--surface-soft-info));
    color: color-mix(in srgb, var(--accent-cyan) 80%, var(--text-main));
  }

  :root[data-theme="light"] .workspace-footer-panel {
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--surface-elevated) 100%, transparent), color-mix(in srgb, var(--surface-overlay-strong) 96%, transparent)),
      radial-gradient(circle at 90% 0%, color-mix(in srgb, var(--accent-cyan) 10%, transparent), transparent 36%);
  }

  :root[data-theme="light"] .workspace-footer-mark {
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
  }

  @media (max-width: 720px) {
    .workspace-footer-panel {
      grid-template-columns: auto minmax(0, 1fr);
    }
    .workspace-footer-meta {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
    }
  }
</style>
