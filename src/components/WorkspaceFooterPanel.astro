---
---
<footer class="panel workspace-footer-panel">
  <div class="workspace-footer-mark">V4</div>
  <div class="workspace-footer-copy">
    <strong>酒馆卡片构建器</strong>
    <span>作者：wominIII</span>
    <p>用于 SillyTavern 角色卡、世界书、正则与 MVU 工作流。</p>
  </div>
  <div class="workspace-footer-meta">
    <a class="workspace-footer-github" href="https://github.com/wominIII" target="_blank" rel="noopener noreferrer">
      <span>GH</span>
      GitHub 主页
    </a>
    <span>豫ICP备2026000549号</span>
  </div>
</footer>

<style>
  .workspace-footer-panel {
    min-height: 134.5px;
    max-height: none;
    overflow: hidden;
    padding: 12px 14px;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 12px;
    border-color: rgba(56, 189, 248, 0.16);
    background:
      linear-gradient(135deg, rgba(15, 23, 42, 0.9), rgba(8, 13, 24, 0.95)),
      radial-gradient(circle at 90% 0%, rgba(56, 189, 248, 0.1), transparent 36%);
  }

  .workspace-footer-mark {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 8px;
    border: 1px solid rgba(56, 189, 248, 0.22);
    background: rgba(8, 47, 73, 0.34);
    color: #67e8f9;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    font-weight: 900;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .workspace-footer-copy {
    min-width: 0;
  }

  .workspace-footer-copy strong {
    display: block;
    color: #e0f2fe;
    font-size: 0.82rem;
    line-height: 1.2;
  }

  .workspace-footer-copy span {
    display: block;
    margin-top: 2px;
    color: #c4b5fd;
    font-size: 0.66rem;
    font-weight: 800;
  }

  .workspace-footer-copy p {
    margin: 6px 0 0;
    color: #64748b;
    font-size: 0.62rem;
    line-height: 1.45;
  }

  .workspace-footer-meta {
    display: flex;
    flex-direction: column;
    gap: 7px;
    align-items: flex-end;
    justify-content: center;
  }

  .workspace-footer-meta span,
  .workspace-footer-meta a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 24px;
    padding: 3px 9px;
    border-radius: 999px;
    border: 1px solid rgba(52, 211, 153, 0.16);
    background: rgba(6, 78, 59, 0.14);
    color: #86efac;
    font-size: 0.54rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    white-space: nowrap;
    text-decoration: none;
  }

  .workspace-footer-github {
    gap: 6px;
    border-color: rgba(56, 189, 248, 0.24) !important;
    background: linear-gradient(135deg, rgba(8, 47, 73, 0.5), rgba(30, 41, 59, 0.72)) !important;
    color: #bae6fd !important;
    box-shadow: 0 4px 14px rgba(8, 47, 73, 0.22);
  }

  .workspace-footer-github span {
    min-height: auto;
    padding: 1px 5px;
    border-radius: 5px;
    border: 1px solid rgba(56, 189, 248, 0.22);
    background: rgba(2, 6, 23, 0.42);
    color: #67e8f9;
    font-size: 0.5rem;
    line-height: 1.2;
  }

  .workspace-footer-meta a:hover {
    border-color: rgba(56, 189, 248, 0.3);
    background: rgba(8, 47, 73, 0.24);
    color: #67e8f9;
  }

  @media (max-width: 720px) {
    .workspace-footer-panel {
      grid-template-columns: auto minmax(0, 1fr);
    }
    .workspace-footer-meta {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
    }
  }
</style>
